# ==============================================================================
# COUNCIL OF HIGH INTELLIGENCE — ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================

# The primary API key for your LLM provider.
COUNCIL_API_KEY=your_api_key_here

# The base URL of the LLM API endpoint.
# - OpenRouter: https://openrouter.ai/api/v1
# - LiteLLM Local Proxy: http://localhost:4000
# - Ollama Local: http://localhost:11434/v1
COUNCIL_BASE_URL=https://openrouter.ai/api/v1

# The model name to be used by the council members and the Chairman.
# - OpenRouter: deepseek/deepseek-v4-flash
# - LiteLLM / OpenAI: gpt-4o or claude-3-5-sonnet
# - Ollama Local: llama3
COUNCIL_MODEL=deepseek/deepseek-v4-flash

# Whether to enable reasoning parameters in LLM calls (e.g. for DeepSeek models)
# Set to 'true' or 'false'.
COUNCIL_REASONING=true
